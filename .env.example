# Digital Link Resolver (our solution provider's DL — used by seed:digital-links)
DL_SERVER=http://localhost
DL_PORT=7088
DL_API_KEY=your-dl-api-key-here

# Web Vocabulary (our solution provider's webvoc — used by seed:master-data)
WEBVOC_SERVER=http://localhost
WEBVOC_PORT=7087
WEBVOC_API_KEY=your-webvoc-api-key-here

# EPCIS (our solution provider's EPCIS — used by seed:events)
EPCIS_SERVER=http://localhost
EPCIS_PORT=7086
EPCIS_API_KEY=your-epcis-api-key-here

# Capability service (GDST tool)
CAPABILITY_SERVICE_URL=https://capability-service.traceability-dialogue.org
CAPABILITY_API_KEY=ec6e6c5f-4464-4291-b029-4c56f8f77298
GDST_VERSION=12

# Our solution registration (sent in step 1)
SOLUTION_NAME=oliopass ver.2.0
SOLUTION_VERSION=2.0
SOLUTION_PGLN=
# Public URL of our DL resolver — the URL the capability tool will reach in steps 4/5
SOLUTION_PROVIDER_PUBLIC_URL=http://210.113.134.235:24241/digitallink
# Public URL of our EPCIS Query Interface — referenced inside DL gs1:epcis links
SOLUTION_PROVIDER_PUBLIC_EPCIS_URL=http://210.113.134.235:24242/epcis/v2
# Public URL of our Web Vocabulary — referenced inside DL gs1:masterData links
SOLUTION_PROVIDER_PUBLIC_WEBVOC_URL=http://210.113.134.235:24240/gs1webvoc
# API key the capability tool will use when calling our DL/EPCIS in steps 4/5
SOLUTION_PROVIDER_API_KEY=
# Comma-separated EPC(s) we generated, returned to capability tool in step 3
SOLUTION_PROVIDER_GENERATED_EPCS=
